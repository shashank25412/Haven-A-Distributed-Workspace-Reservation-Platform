# -----------------------------------------------------------------------------
# Haven Local Environment Configuration
#
# Copy this file to `.env` for local development:
#
#     cp .env.example .env
#
# Do not store secrets or machine-specific credentials in this example file.
# -----------------------------------------------------------------------------

# Address on which the Haven HTTP server listens.
#
# Use 0.0.0.0 inside Docker so the process accepts traffic through the
# container network and published host port.
HVN_HTTP_ADDRESS=0.0.0.0

# TCP port exposed by the Haven HTTP server.
#
# Valid range: 1-65535
HVN_HTTP_PORT=8080